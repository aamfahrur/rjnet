APP_NAME=RJNet
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=Asia/Jakarta

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# =============================================================================
# Database
# =============================================================================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=rjnet
DB_USERNAME=root
DB_PASSWORD=

# =============================================================================
# Redis & Queue
# =============================================================================
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

QUEUE_CONNECTION=redis
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
SESSION_DRIVER=database
SESSION_LIFETIME=120

# =============================================================================
# Broadcasting / WebSocket (Laravel Reverb)
# =============================================================================
BROADCAST_DRIVER=reverb

REVERB_APP_ID=rjnet
REVERB_APP_KEY=rjnet_app_key
REVERB_APP_SECRET=rjnet_app_secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

# =============================================================================
# Mail
# =============================================================================
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@rjnet.id"
MAIL_FROM_NAME="${APP_NAME}"

# =============================================================================
# Payment Gateways
# =============================================================================
# iPaymu
IPAYMU_VA=
IPAYMU_API_KEY=
IPAYMU_SANDBOX=true

# Midtrans
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_MERCHANT_ID=
MIDTRANS_SANDBOX=true

# Duitku
DUITKU_MERCHANT_CODE=
DUITKU_API_KEY=
DUITKU_SANDBOX=true

# =============================================================================
# Mikrotik Defaults
# =============================================================================
MIKROTIK_API_PORT=8728
MIKROTIK_API_SSL_PORT=8729
MIKROTIK_TIMEOUT=10
MIKROTIK_MAX_RETRIES=3
MIKROTIK_METRICS_INTERVAL=5

# =============================================================================
# Telegram Notification
# =============================================================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# =============================================================================
# Billing
# =============================================================================
BILLING_GRACE_PERIOD_DAYS=7
BILLING_DUE_OFFSET_DAYS=10
BILLING_AUTO_SUSPEND=true
BILLING_AUTO_UNSUSPEND=true

# =============================================================================
# Monitoring
# =============================================================================
MONITORING_ENABLED=true
MONITORING_INTERVAL=5
MONITORING_RETENTION_DAYS=30
ALERT_CPU_THRESHOLD=80
ALERT_MEMORY_THRESHOLD=85

# =============================================================================
# AWS (optional, for S3 storage)
# =============================================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
